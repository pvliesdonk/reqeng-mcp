# OIDC authentication example
# See docs/guides/authentication.md for setup instructions

REQENG_MCP_BASE_URL=https://mcp.example.com
REQENG_MCP_OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
REQENG_MCP_OIDC_CLIENT_ID=mcp-client
REQENG_MCP_OIDC_CLIENT_SECRET=your-client-secret
REQENG_MCP_OIDC_JWT_SIGNING_KEY=your-signing-key   # openssl rand -hex 32
REQENG_MCP_READ_ONLY=false
