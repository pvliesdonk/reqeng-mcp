# Requirements Engineering MCP environment variables (copy to .env and fill in).

# --- Server ---
# REQENG_MCP_TRANSPORT=stdio   # stdio | http | sse
# REQENG_MCP_HOST=127.0.0.1
# REQENG_MCP_PORT=8000
# REQENG_MCP_HTTP_PATH=/mcp
# REQENG_MCP_BASE_URL=https://mcp.example.com

# --- Auth (pick one flavor) ---
# REQENG_MCP_BEARER_TOKEN=<secret>

# REQENG_MCP_OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
# REQENG_MCP_OIDC_CLIENT_ID=<client-id>
# REQENG_MCP_OIDC_CLIENT_SECRET=<client-secret>
# REQENG_MCP_OIDC_AUDIENCE=
# REQENG_MCP_OIDC_REQUIRED_SCOPES=openid
# REQENG_MCP_OIDC_JWT_SIGNING_KEY=<hex-string>

# --- Domain (populate from your ProjectConfig) ---
